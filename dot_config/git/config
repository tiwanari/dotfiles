[core]
	autocrlf = false
	editor = nvim
	precomposeunicode = true
	quotepath = false
	ignorecase = false

[init]
	defaultBranch = main

[push]
	default = current
	autoSetupRemote = true

[pull]
	ff = only

[fetch]
	prune = true

[merge]
	conflictStyle = zdiff3

[alias]
	a = add
	st = status
	sh = show
	d = diff
	di = diff
	dh = diff HEAD
	f = fetch
	ls = ls-files -t
	cm = commit
	cmm = commit -am
	co = checkout
	l = log
	lg = log --graph
	lo = log --graph --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(green)- %an, %cr%Creset'
	la = log --oneline --decorate --graph --branches --tags --remotes
	b = branch
	ba = branch -a

[user]
	name = tiwanari
	email = tatsuyaw0c@gmail.com

[grep]
	lineNumber = true

[diff]
	tool = nvimdiff

[difftool "nvimdiff"]
	cmd = "nvim -R -d -c \"wincmd l\" -d \"$LOCAL\" \"$REMOTE\""

[mergetool "nvimdiff"]
	cmd = "nvim -d -c \"4wincmd w | wincmd J\" \"$LOCAL\" \"$BASE\" \"$REMOTE\"  \"$MERGED\""
